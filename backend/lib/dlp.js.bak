// ----------------------------------------------------
// 🔐 INPUT DLP (HARDENED — PHONE IMPROVED)
// ----------------------------------------------------
export function runDLPScan(text = "") {
  let sanitized = text;

  // ----------------------------------------------------
  // 🔍 PATTERNS
  // ----------------------------------------------------
  const ssnRegex = /\b\d{3}-\d{2}-\d{4}\b/i;
  const ssnContextRegex = /(ssn|social security)/i;

  const emailRegex = /\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}\b/i;

  // 🔥 IMPROVED PHONE (matches real-world formats)
  const phoneRegex = /\+?1?\s*\(?\d{3}\)?[\s.-]?\d{3}[\s.-]?\d{4}\b/g;

  // ----------------------------------------------------
  // 🚨 HIGH-RISK DATA → BLOCK (ONLY IF CONTEXT MATCHES)
  // ----------------------------------------------------
  if (ssnRegex.test(text) && ssnContextRegex.test(text)) {
    return {
      sanitized: text,
      block: true,
      reason: "SSN detected"
    };
  }

  // ----------------------------------------------------
  // ✂️ MEDIUM-RISK DATA → REDACT (ALLOW FLOW)
  // ----------------------------------------------------
  sanitized = sanitized
    .replace(emailRegex, "[REDACTED_EMAIL]")
    .replace(phoneRegex, "[REDACTED_PHONE]");

  return {
    sanitized,
    block: false,
    reason: "redacted"
  };
}

// ----------------------------------------------------
// 🔐 OUTPUT DLP (FULLY HARDENED)
// ----------------------------------------------------
export function stripSensitiveFields(text) {
  if (!text || typeof text !== "string") return text;

  let output = text;

  // -------------------------------
  // EMAIL REDACTION
  // -------------------------------
  output = output.replace(
    /\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}\b/gi,
    "[REDACTED_EMAIL]"
  );

  // -------------------------------
  // PHONE REDACTION (HARDENED)
  // -------------------------------
  const phonePatterns = [
    /\+?1?\s*\(?\d{3}\)?[\s.-]?\d{3}[\s.-]?\d{4}\b/g,
    /\b\d{3}[\s.-]\d{3}[\s.-]\d{4}\b/g
  ];

  phonePatterns.forEach((pattern) => {
    output = output.replace(pattern, "[REDACTED_PHONE]");
  });

  // -------------------------------
  // ADDRESS REDACTION (FULL HARDENED)
  // -------------------------------
  const addressPatterns = [
    // Full address with ordinal (30th, 21st, etc), directional, optional unit, optional city/state/zip
    
/\b\d{1,5}\s+\d{1,3}(?:st|nd|rd|th)\s+[A-Za-z]+\s+(?:Street|St|Avenue|Ave|Road|Rd|Boulevard|Blvd|Lane|Ln|Drive|Dr|Court|Ct|Way|Wy|Place|Pl)\s*(?:[NSEW]{1,2})?(?:\s+(?:Apt|Unit|Suite|Ste)\s*\w+)?(?:,\s*[A-Za-z\s]+,\s*[A-Z]{2}\s*\d{5})?\b/gi,

    // Standard street address (no ordinal)
    /\b\d{1,5}\s+[A-Za-z0-9.\s]+?\s(?:Street|St|Avenue|Ave|Road|Rd|Boulevard|Blvd|Lane|Ln|Drive|Dr|Court|Ct|Way|Wy|Place|Pl)\s*(?:[NSEW]{1,2})?(?:,\s*[A-Za-z\s]+,\s*[A-Z]{2}\s*\d{5})?\b/gi
  ];

  addressPatterns.forEach((pattern) => {
    output = output.replace(pattern, "[REDACTED_ADDRESS]");
  });

  // 🔥 FINAL CLEANUP — REMOVE PARTIAL ADDRESS LEAKS
  output = output.replace(
    /\[REDACTED_ADDRESS\][^\n]*/gi,
    "[REDACTED_ADDRESS]"
  );

  // -------------------------------
  // SSN (STRICT BLOCK)
  // -------------------------------
  if (/\b\d{3}-\d{2}-\d{4}\b/.test(output)) {
    return "[BLOCKED: SENSITIVE CONTENT]";
  }

  return output;
}
